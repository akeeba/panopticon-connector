<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.4/phpunit.xsd"
         bootstrap="tests/unit/bootstrap.php"
         cacheResult="false"
         colors="true"
         defaultTestSuite="unit"
>
    <testsuites>
        <testsuite name="unit">
            <directory>tests/unit</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory suffix=".php">component/api/src</directory>
        </include>
    </source>

    <!--
        This suite runs pure PHP logic extracted out of Joomla-coupled classes, with no Joomla
        framework, database, or HTTP involved (see tests/unit/bootstrap.php). It is intentionally
        strict (default PHPUnit 11 behaviour: warnings/notices/deprecations fail the run). The
        relaxed integration suite lives in phpunit-integration.xml.
    -->
</phpunit>
