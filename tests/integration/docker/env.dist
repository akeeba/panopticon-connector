# Configuration for the Dockerized integration test stack.
#
# Copy this file to .env and edit as needed, or just run run-tests.sh which
# creates .env from this template automatically on first run.

# ----------------------------------------------------------------------------
# Joomla version to test against when not overridden on the run-tests.sh
# command line. May be a full version (5.2.1), a branch (5.2) or a major (5).
# For a partial version the latest matching STABLE release is resolved.
# ----------------------------------------------------------------------------
JOOMLA_VERSION=5

# ----------------------------------------------------------------------------
# Docker image tags for the LAMP stack. PHP 8.3 works across Joomla 4/5/6.
# ----------------------------------------------------------------------------
PHP_VERSION=8.3
DB_IMAGE=mariadb:11.4

# ----------------------------------------------------------------------------
# Database.
# ----------------------------------------------------------------------------
DB_ROOT_PASSWORD=rootpw
DB_NAME=joomla_test
DB_USER=root
DB_PASSWORD=rootpw
DB_PREFIX=jtest_

# ----------------------------------------------------------------------------
# Host ports.
# ----------------------------------------------------------------------------
# The site is reachable at http://localhost:${WEB_PORT} from the host.
WEB_PORT=8080
